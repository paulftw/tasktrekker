    "eslint-config-next": "16.2.4",
    "graphql": "^16.13.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "relay-compiler": "^20.1.1",
    "relay-test-utils": "^20.1.1",
