    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "sonner": "^1.4.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@swc/plugin-relay": "^12.8.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
